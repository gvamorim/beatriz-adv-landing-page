---
export interface Props {
  delay?: 0 | 100 | 200 | 300 | 400 | 500 | 600;
  as?: string;
  class?: string;
}

const { delay = 0, as: Tag = "div", class: className = "" } = Astro.props;
---

<Tag data-reveal data-delay={delay} class={className} style={delay ? `transition-delay:${delay}ms` : undefined}>
  <slot />
</Tag>
