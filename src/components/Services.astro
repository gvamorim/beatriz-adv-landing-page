---
import Icon from "./Icon.astro";
import Reveal from "./Reveal.astro";

const services = [
  {
    id: "assessoria",
    icon: "document",
    title: "Assessoria Consultiva Contínua",
    desc: "Suporte jurídico-trabalhista recorrente. Tire dúvidas, valide decisões e tenha segurança em cada etapa.",
    tag: "Mensalidade",
  },
  {
    id: "treinamentos",
    icon: "graduation",
    title: "Treinamentos para Gestores",
    desc: "Capacitação prática sobre legislação trabalhista, boas práticas de gestão, direitos e deveres.",
    tag: "Sob demanda",
  },
  {
    id: "nr1",
    icon: "compass",
    title: "NR-1 e Saúde Mental",
    desc: "Adequação à nova NR-1: mapeamento de riscos psicossociais, PGRS e implantação de processos.",
    tag: "Destaque 2026",
  },
  {
    id: "compliance",
    icon: "building",
    title: "Compliance Trabalhista",
    desc: "Políticas internas, regulamento empresarial e cultura de prevenção integrada ao RH.",
    tag: "Programa recorrente",
  },
  {
    id: "palestras",
    icon: "mic",
    title: "Palestras e Workshops",
    desc: "Temas trabalhistas aplicados à cultura da empresa: assédio, saúde mental, normas de conduta.",
    tag: "In company",
  },
  {
    id: "processos",
    icon: "folder",
    title: "Organização de Processos Internos",
    desc: "Revisão de contratos, documentos admissionais, políticas e procedimentos disciplinares.",
    tag: "Avulso ou incluso",
  },
];
---

<section
  id="servicos"
  class="relative overflow-hidden bg-[var(--color-marrom)] py-24 md:py-32"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-8 left-8 select-none whitespace-nowrap font-serif text-[10rem] font-bold leading-none text-white/[0.03]"
  >
    SERVIÇOS
  </div>

  <div class="container-app relative">
    <div class="mx-auto max-w-2xl text-center">
      <Reveal>
        <span class="eyebrow-plain text-[var(--color-caramelo-lt)]">
          O que a BVC oferece
        </span>
      </Reveal>
      <Reveal delay={100}>
        <h2 class="mt-6 font-serif text-[clamp(1.9rem,3.4vw,2.9rem)] font-bold leading-[1.2] text-[var(--color-bege)]">
          Soluções que fazem sentido para
          <em class="text-[var(--color-caramelo-lt)]">quem é de RH</em>
        </h2>
      </Reveal>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s, i) => (
          <Reveal delay={(i % 3) * 100 as 0 | 100 | 200}>
            <a
              href={`#${s.id}`}
              class="group relative flex h-full flex-col justify-between overflow-hidden rounded-3xl border border-[rgba(181,133,74,0.2)] bg-white/[0.03] p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-caramelo)] hover:bg-[rgba(181,133,74,0.08)]"
            >
              <div>
                <div class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-[rgba(181,133,74,0.45)] bg-[rgba(181,133,74,0.12)] text-[var(--color-caramelo-lt)] transition-colors group-hover:bg-[var(--color-caramelo)] group-hover:text-[var(--color-bege)]">
                  <Icon name={s.icon} size={22} />
                </div>
                <h3 class="mt-6 font-serif text-[1.35rem] font-bold leading-[1.3] text-[var(--color-bege)]">
                  {s.title}
                </h3>
                <p class="mt-3 text-[0.9rem] font-light leading-[1.7] text-[rgba(242,235,224,0.6)]">
                  {s.desc}
                </p>
              </div>

              <div class="mt-7 flex items-center justify-between">
                <span class="chip">{s.tag}</span>
                <span class="inline-flex items-center gap-2 text-[0.72rem] font-medium uppercase tracking-[0.18em] text-[var(--color-caramelo-lt)] opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  Ver detalhes
                  <Icon name="arrow-right" size={14} />
                </span>
              </div>

              <span
                aria-hidden="true"
                class="absolute bottom-0 left-8 right-8 h-[2px] w-0 bg-[var(--color-caramelo)] transition-all duration-500 group-hover:w-[calc(100%-4rem)]"
              />
            </a>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
